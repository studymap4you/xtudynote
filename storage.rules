rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    function isActiveSuperAdmin() {
      return request.auth != null
        && userDoc().role == 'super_admin'
        && userDoc().accountStatus == 'active';
    }
    function isActiveTeacher() {
      return request.auth != null
        && userDoc().role == 'teacher'
        && userDoc().accountStatus == 'active';
    }
    function isActiveStudent() {
      return request.auth != null
        && userDoc().role == 'student'
        && userDoc().accountStatus == 'active';
    }

    match /verification/{uid}/{fileName} {
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024;

      allow read: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );

      allow delete: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );
    }

    match /contents/{authorId}/{allPaths=**} {
      /** 본인(교사/관리자) 업로드 또는 마스터가 검수 시 제출자 폴더로 복사 */
      allow create, update: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && (
          (request.auth.uid == authorId && (isActiveSuperAdmin() || isActiveTeacher()))
          || isActiveSuperAdmin()
        );

      allow read: if request.auth != null
        && (isActiveSuperAdmin() || isActiveTeacher() || isActiveStudent());

      allow delete: if request.auth != null
        && request.auth.uid == authorId
        && (isActiveSuperAdmin() || isActiveTeacher());
    }

    /** Rich-text editor images (Q&A, 자료 설명 등) — 공개 URL로 삽입 */
    match /editor_images/{uid}/{allPaths=**} {
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow read: if true;

      allow delete: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );
    }

    /** 에디터 본문에 넣는 비이미지 첨부(링크용 PDF 등) */
    match /editor_attachments/{uid}/{allPaths=**} {
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 35 * 1024 * 1024;

      allow read: if true;

      allow delete: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );
    }

    /** 교재 자동 생성 4단계 — 본인 세션별 Word 패키지 (.docx) */
    match /textbook_auto/{uid}/{sessionId}/{fileName} {
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && (isActiveTeacher() || isActiveSuperAdmin())
        && request.resource.size < 35 * 1024 * 1024
        && (fileName == 'student.docx' || fileName == 'teacher.docx');

      allow read: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );

      allow delete: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );
    }

    /** 학습지 배포용 로컬 첨부 (업로더·마스터만 직접 읽기; 학생은 Functions 서명 URL) */
    match /worksheet_uploads/{uid}/{allPaths=**} {
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && (isActiveTeacher() || isActiveSuperAdmin())
        && request.resource.size < 35 * 1024 * 1024;

      allow read: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );

      allow delete: if request.auth != null && (
        request.auth.uid == uid
        || isActiveSuperAdmin()
      );
    }

    match /pending_materials/{uploaderId}/{requestId}/{allPaths=**} {
      allow create, update: if request.auth != null
        && request.auth.uid == uploaderId
        && (isActiveStudent() || isActiveTeacher() || isActiveSuperAdmin())
        && request.resource.size < 50 * 1024 * 1024;

      allow read: if request.auth != null && (
        request.auth.uid == uploaderId
        || isActiveSuperAdmin()
      );

      allow delete: if request.auth != null && (
        request.auth.uid == uploaderId
        || isActiveSuperAdmin()
      );
    }

    match /submissions/{teacherId}/{studentId}/{submissionId}/{fileName} {
      allow create, update: if request.auth != null
        && request.auth.uid == studentId
        && isActiveStudent()
        && request.resource.size < 50 * 1024 * 1024;

      allow read: if request.auth != null && (
        request.auth.uid == studentId
        || request.auth.uid == teacherId
        || isActiveSuperAdmin()
      );

      allow delete: if request.auth != null && (
        (request.auth.uid == studentId && isActiveStudent())
        || isActiveSuperAdmin()
      );
    }

    /** 지식 큐레이션 — 마스터가 강의실·큐레이션에 붙일 파일 업로드 */
    match /knowledge_curation_uploads/{uid}/{curationId}/{allPaths=**} {
      allow create, update: if isActiveSuperAdmin()
        && request.auth.uid == uid
        && request.resource.size < 45 * 1024 * 1024;

      allow read: if request.auth != null;

      allow delete: if isActiveSuperAdmin() && request.auth.uid == uid;
    }

    /**
     * 레거시 `landing_hero/` 객체 — 신규 업로드는 앱에서 제거됨.
     * 공개 읽기만 유지(이미 배포된 URL 깨짐 방지). 삭제는 마스터만.
     */
    match /site_assets/landing_hero/{allPaths=**} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if isActiveSuperAdmin();
    }

    /** 동영상 강의 카드 썸네일 (/videos) — 마스터만 업로드, 공개 읽기 */
    match /video_catalog_thumbnails/{uid}/{allPaths=**} {
      allow create, update: if isActiveSuperAdmin()
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow read: if true;

      allow delete: if isActiveSuperAdmin() && request.auth.uid == uid;
    }

    /**
     * 강의실 홈 홍보 썸네일 — 해당 강의실 소유 선생님(또는 동일 UID 마스터)만 업로드, 공개 읽기
     */
    match /classroom_landing_promo/{classroomId}/{fileName} {
      function classroomDoc() {
        return firestore.get(/databases/(default)/documents/classrooms/$(classroomId));
      }
      function isOwnerTeacher() {
        return request.auth != null
          && firestore.exists(/databases/(default)/documents/classrooms/$(classroomId))
          && classroomDoc().data.teacherId == request.auth.uid;
      }

      allow create, update: if (isActiveTeacher() || isActiveSuperAdmin())
        && isOwnerTeacher()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow read: if true;

      allow delete: if (isActiveTeacher() || isActiveSuperAdmin()) && isOwnerTeacher();
    }

    /** 디지털마켓 상품 이미지 — 마스터만 업로드, 공개 읽기 */
    match /digital_market_images/{uid}/{allPaths=**} {
      allow create, update: if isActiveSuperAdmin()
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow read: if true;

      allow delete: if isActiveSuperAdmin() && request.auth.uid == uid;
    }

    /** 엑스터디마켓 상품 이미지 — 마스터만 업로드, 공개 읽기 */
    match /xtudy_market_images/{uid}/{allPaths=**} {
      allow create, update: if isActiveSuperAdmin()
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow read: if true;

      allow delete: if isActiveSuperAdmin() && request.auth.uid == uid;
    }

    /** 홈 전체 배경 — 이미지 10MB·동영상 40MB 이하, 공개 읽기 */
    match /site_assets/landing_page_bg/{allPaths=**} {
      allow create, update: if isActiveSuperAdmin()
        && (
          (
            request.resource.contentType.matches('image/.*')
            && request.resource.size < 10 * 1024 * 1024
          )
          || (
            request.resource.contentType.matches('video/.*')
            && request.resource.size < 40 * 1024 * 1024
          )
        );

      allow read: if true;

      allow delete: if isActiveSuperAdmin();
    }
  }
}
