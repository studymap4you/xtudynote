rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ——— 공통 헬퍼 ———
    function signedIn() {
      return request.auth != null;
    }
    function tokenEmailLower() {
      return request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }
    function isSuperAdminEmail() {
      return tokenEmailLower() == 'studymap0904@gmail.com';
    }
    function userData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function isActiveSuperAdmin() {
      return signedIn()
        && userData(request.auth.uid).role == 'super_admin'
        && userData(request.auth.uid).accountStatus == 'active';
    }
    function isActiveTeacher() {
      return signedIn()
        && userData(request.auth.uid).role == 'teacher'
        && userData(request.auth.uid).accountStatus == 'active';
    }
    function isActiveStudent() {
      return signedIn()
        && userData(request.auth.uid).role == 'student'
        && userData(request.auth.uid).accountStatus == 'active';
    }
    function isApprovedLibraryContent() {
      return resource.data.status == 'approved'
        && (
          resource.data.type == 'share'
          || resource.data.type == 'paid'
          || resource.data.type == 'homework'
        );
    }
    function isAuthor() {
      return signedIn() && resource.data.authorId == request.auth.uid;
    }
    /** 로그인 + users 문서상 활성 (강의실 목록·입장 등) */
    function isSignedInActiveAccount() {
      return signedIn() && userData(request.auth.uid).accountStatus == 'active';
    }
    /** 강의실 소유자만 classroomId 연결 가능 */
    function ownsClassroom(classroomId) {
      return exists(/databases/$(database)/documents/classrooms/$(classroomId))
        && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId
          == request.auth.uid;
    }
    /** classrooms 문서용 — memberStudentIds 없으면 빈 목록 */
    function classroomOldMemberIds() {
      return (
        'memberStudentIds' in resource.data
        && resource.data.memberStudentIds is list
      )
        ? resource.data.memberStudentIds
        : [];
    }
    /** 무료 강의실에 활성 학생이 본인 UID만 arrayUnion 하는 업데이트 */
    function studentSelfEnrollFreeClassroom() {
      return isActiveStudent()
        && request.auth.uid != resource.data.teacherId
        && (!('pricingType' in resource.data) || resource.data.pricingType == 'free')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberStudentIds'])
        && request.resource.data.memberStudentIds is list
        && request.resource.data.memberStudentIds.size() <= 200
        && request.resource.data.memberStudentIds.size() == classroomOldMemberIds().size() + 1
        && request.resource.data.memberStudentIds.hasAll(classroomOldMemberIds())
        && request.auth.uid in request.resource.data.memberStudentIds
        && !(request.auth.uid in classroomOldMemberIds())
        && request.resource.data.teacherId == resource.data.teacherId;
    }
    /** 본인 UID만 memberStudentIds에서 제거 (수강 취소) */
    function studentSelfLeaveClassroomMembers() {
      return isSignedInActiveAccount()
        && request.auth.uid != resource.data.teacherId
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberStudentIds'])
        && request.resource.data.memberStudentIds is list
        && classroomOldMemberIds().hasAll(request.resource.data.memberStudentIds)
        && classroomOldMemberIds().size() == request.resource.data.memberStudentIds.size() + 1
        && request.auth.uid in classroomOldMemberIds()
        && !(request.auth.uid in request.resource.data.memberStudentIds);
    }
    /** contents 읽기 — resource = content 문서 */
    function contentHasClassroomId() {
      return 'classroomId' in resource.data
        && resource.data.classroomId is string
        && resource.data.classroomId.size() > 0;
    }
    function contentClassroomData() {
      return get(/databases/$(database)/documents/classrooms/$(resource.data.classroomId)).data;
    }
    function canReadContentLinkedToMyClassroom() {
      return isSignedInActiveAccount()
        && contentHasClassroomId()
        && exists(/databases/$(database)/documents/classrooms/$(resource.data.classroomId))
        && (
          contentClassroomData().teacherId == request.auth.uid
          || (
            'memberStudentIds' in contentClassroomData()
            && contentClassroomData().memberStudentIds is list
            && request.auth.uid in contentClassroomData().memberStudentIds
          )
        );
    }
    function contentClickCountBefore() {
      return 'clickCount' in resource.data ? resource.data.clickCount : 0;
    }
    /** 조회수 증가만 (다른 필드 불변) */
    function isClickCountIncrementOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount'])
        && request.resource.data.clickCount is int
        && request.resource.data.clickCount > contentClickCountBefore()
        && request.resource.data.clickCount <= contentClickCountBefore() + 20;
    }

    // ——— users ———
    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isActiveSuperAdmin()
      );

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.keys().hasAll(['email', 'role', 'accountStatus', 'createdAt'])
        && (
          (request.resource.data.role == 'super_admin' && isSuperAdminEmail())
          || (request.resource.data.role == 'student')
          || (request.resource.data.role == 'pending_teacher')
        );

      allow update: if
        (isActiveSuperAdmin() && request.resource.data.email == resource.data.email)
        || (
          signedIn()
          && request.auth.uid == userId
          && isSuperAdminEmail()
          && userData(userId).accountStatus != 'banned'
          && request.resource.data.role == 'super_admin'
          && request.resource.data.email == resource.data.email
          && request.resource.data.accountStatus == resource.data.accountStatus
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])
        )
        || (
          signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.accountStatus == resource.data.accountStatus
          && (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['displayName', 'verificationFileUrls', 'verificationSubmittedAt'])
            || (
              userData(userId).role == 'teacher'
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['bankName', 'bankAccountNumber', 'accountHolder'])
            )
            || (
              userData(userId).role == 'student'
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['bankName', 'bankAccountNumber', 'accountHolder'])
            )
          )
        );

      /** Signal Logic — KSAT 스타일 분석 리포트 (본인만 읽기·쓰기) */
      match /signal_logic_reports/{reportId} {
        allow read: if signedIn() && request.auth.uid == userId;

        allow create: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && request.resource.data.keys().hasAll(['passage', 'analysis', 'schemaVersion', 'createdAt', 'model'])
          && request.resource.data.passage is string
          && request.resource.data.passage.size() > 0
          && request.resource.data.passage.size() <= 120000
          && request.resource.data.analysis is map
          && request.resource.data.schemaVersion is int
          && request.resource.data.schemaVersion == 1
          && request.resource.data.model is string
          && request.resource.data.model.size() <= 120;

        allow delete: if signedIn() && request.auth.uid == userId;

        allow update: if false;
      }

      /** 지문 심층 분석 — 문장·의미 단위 리포트 (본인만 읽기·쓰기) */
      match /passage_deep_reports/{reportId} {
        allow read: if signedIn() && request.auth.uid == userId;

        allow create: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && request.resource.data.keys().hasAll(['passage', 'analysis', 'schemaVersion', 'createdAt', 'model'])
          && request.resource.data.passage is string
          && request.resource.data.passage.size() > 0
          && request.resource.data.passage.size() <= 120000
          && request.resource.data.analysis is map
          && request.resource.data.schemaVersion is int
          && request.resource.data.schemaVersion == 1
          && request.resource.data.model is string
          && request.resource.data.model.size() <= 120;

        allow delete: if signedIn() && request.auth.uid == userId;

        allow update: if false;
      }

      /** 학습지 배포용 주소록 — 교사·승인 관리자 본인만 (표시명·이메일은 선택, UID는 문서 ID와 동일) */
      match /worksheet_roster/{entryId} {
        allow read: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin');

        allow create: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin')
          && request.resource.data.keys().hasAll(['studentUid', 'createdAt'])
          && request.resource.data.studentUid is string
          && request.resource.data.studentUid == entryId
          && request.resource.data.studentUid.size() >= 8
          && request.resource.data.studentUid.size() <= 128
          && request.resource.data.createdAt != null
          && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 120))
          && (!('emailLower' in request.resource.data)
            || (request.resource.data.emailLower is string && request.resource.data.emailLower.size() <= 200));

        allow update: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin')
          && resource.data.studentUid == request.resource.data.studentUid
          && request.resource.data.studentUid == entryId
          && request.resource.data.keys().hasAll(['studentUid', 'createdAt'])
          && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 120))
          && (!('emailLower' in request.resource.data)
            || (request.resource.data.emailLower is string && request.resource.data.emailLower.size() <= 200));

        allow delete: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin');
      }

      /** 학습지 배포용 그룹(예: A반) — UID 목록만 저장 */
      match /worksheet_groups/{groupId} {
        allow read: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin');

        allow create: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin')
          && request.resource.data.keys().hasAll(['name', 'studentUids', 'createdAt'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
          && request.resource.data.studentUids is list
          && request.resource.data.studentUids.size() > 0
          && request.resource.data.studentUids.size() <= 200
          && request.resource.data.createdAt != null;

        allow update: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin')
          && request.resource.data.keys().hasAll(['name', 'studentUids', 'createdAt'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
          && request.resource.data.studentUids is list
          && request.resource.data.studentUids.size() > 0
          && request.resource.data.studentUids.size() <= 200;

        allow delete: if signedIn()
          && request.auth.uid == userId
          && userData(userId).accountStatus != 'banned'
          && (userData(userId).role == 'teacher' || userData(userId).role == 'super_admin');
      }
    }

    // ——— contents (라이브러리·강의실 연동 시 classroomId 검증) ———
    match /contents/{docId} {
      allow read: if isActiveSuperAdmin()
        || isAuthor()
        || isApprovedLibraryContent()
        || canReadContentLinkedToMyClassroom();

      allow create: if isActiveSuperAdmin()
        || (
          isActiveTeacher()
          && request.resource.data.authorId == request.auth.uid
          && (
            !('classroomId' in request.resource.data)
            || request.resource.data.classroomId == null
            || ownsClassroom(request.resource.data.classroomId)
          )
        );

      allow update: if isActiveSuperAdmin() || (
        isActiveTeacher()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
      ) || (
        isSignedInActiveAccount()
        && isApprovedLibraryContent()
        && isClickCountIncrementOnly()
      );

      /** 삭제: 마스터는 전체 — 그 외 활성 계정은 본인 authorId 문서만 */
      allow delete: if isActiveSuperAdmin() || (
        isSignedInActiveAccount()
        && resource.data.authorId == request.auth.uid
      );
    }

    /** 홈 프리미엄 노출 순서 등 (마스터만 쓰기) */
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isActiveSuperAdmin();
    }

    /** 공개 동영상 링크 목록 (랜딩 /videos) */
    match /video_catalog/{vid} {
      allow read: if true;

      allow create: if (isActiveSuperAdmin() || isActiveTeacher())
        && request.auth.uid == request.resource.data.createdBy
        && request.resource.data.keys().hasAll(['title', 'watchUrl', 'createdAt', 'createdBy'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 240
        && request.resource.data.watchUrl is string
        && request.resource.data.watchUrl.size() > 8
        && request.resource.data.watchUrl.size() <= 2048
        && request.resource.data.watchUrl.matches('https?://.*')
        && request.resource.data.createdBy is string
        && (
          !('description' in request.resource.data)
          || (
            request.resource.data.description is string
            && request.resource.data.description.size() <= 2000
          )
        );

      allow update: if isActiveSuperAdmin()
        || (
          isActiveTeacher()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 240
          && request.resource.data.watchUrl is string
          && request.resource.data.watchUrl.size() > 8
          && request.resource.data.watchUrl.matches('https?://.*')
          && (
            !('description' in request.resource.data)
            || (
              request.resource.data.description is string
              && request.resource.data.description.size() <= 2000
            )
          )
        );

      allow delete: if isActiveSuperAdmin()
        || (isActiveTeacher() && resource.data.createdBy == request.auth.uid);
    }

    /** AI 시험지 — 링크로 학생 응시 가능, 작성자만 수정 */
    match /ai_exams/{examId} {
      allow read: if resource.data.visibility == 'link'
        || isActiveSuperAdmin()
        || (
          isSignedInActiveAccount()
          && resource.data.teacherId == request.auth.uid
        );

      allow create: if (isActiveTeacher() || isActiveSuperAdmin())
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.visibility == 'link'
        && request.resource.data.questions is list
        && request.resource.data.keys().hasAll([
          'teacherId',
          'title',
          'subject',
          'passage',
          'questions',
          'totalItems',
          'objectiveRatioPercent',
          'visibility',
          'createdAt',
        ]);

      allow update: if (isActiveTeacher() || isActiveSuperAdmin())
        && resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherId == resource.data.teacherId;

      allow delete: if (isActiveTeacher() || isActiveSuperAdmin())
        && resource.data.teacherId == request.auth.uid;
    }

    /**
     * homework_codes — 문서 ID = 전체 과제코드(HW-…).
     * read: get + shortCode 등 쿼리(list). 승인된 과제만 조회 가능.
     */
    match /homework_codes/{code} {
      allow read: if resource.data.status == 'approved';

      allow create, update: if isActiveSuperAdmin() || (
        isActiveTeacher()
        && request.resource.data.authorId == request.auth.uid
        && exists(/databases/$(database)/documents/contents/$(request.resource.data.contentId))
        && get(/databases/$(database)/documents/contents/$(request.resource.data.contentId)).data.authorId
          == request.auth.uid
        && request.resource.data.homeworkCode == code
      );

      allow delete: if isActiveSuperAdmin() || (
        isSignedInActiveAccount()
        && resource.data.authorId == request.auth.uid
      );
    }

    // ——— content_qa ———
    match /content_qa/{qaId} {
      /** 본인 질문 또는 해당 자료 업로더(답변)·슈퍼관리자만 조회 */
      allow read: if signedIn()
        && (
          resource.data.studentId == request.auth.uid
          || get(/databases/$(database)/documents/contents/$(resource.data.contentId)).data.authorId
            == request.auth.uid
          || isActiveSuperAdmin()
        );
      allow create: if signedIn()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.keys().hasAll(['contentId', 'studentId', 'question', 'createdAt'])
        && request.resource.data.question is string
        && request.resource.data.answer == null;
      allow update: if signedIn()
        && get(/databases/$(database)/documents/contents/$(resource.data.contentId)).data.authorId
          == request.auth.uid
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.contentId == resource.data.contentId
        && request.resource.data.question == resource.data.question
        && request.resource.data.answer is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answer', 'answeredAt']);
    }

    // ——— submissions ———
    match /submissions/{subId} {
      allow read: if isActiveSuperAdmin()
        || (signedIn() && resource.data.studentId == request.auth.uid)
        || (signedIn() && resource.data.teacherId == request.auth.uid);

      allow create: if isActiveStudent()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'contentId', 'studentId', 'teacherId', 'submissionText', 'submissionFiles',
          'score', 'feedback', 'submittedAt'
        ])
        && get(/databases/$(database)/documents/contents/$(request.resource.data.contentId)).data.authorId
          == request.resource.data.teacherId;

      allow update: if isActiveSuperAdmin()
        || (
          signedIn()
          && resource.data.teacherId == request.auth.uid
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.contentId == resource.data.contentId
          && request.resource.data.teacherId == resource.data.teacherId
          && request.resource.data.submissionText == resource.data.submissionText
          && request.resource.data.submissionFiles == resource.data.submissionFiles
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score', 'feedback', 'updatedAt'])
        );

      allow delete: if isActiveSuperAdmin();
    }

    // ——— student_downloads ———
    match /student_downloads/{docId} {
      allow read, delete: if signedIn() && resource.data.studentId == request.auth.uid;
      allow create, update: if signedIn()
        && request.resource.data.studentId == request.auth.uid
        && docId == request.auth.uid + '_' + request.resource.data.contentId;
    }

    // ——— material_requests (선택 필드 classroomId — 소유 강의실만) ———
    match /material_requests/{reqId} {
      allow create: if signedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.materialType in ['share', 'paid', 'homework']
        && request.resource.data.submitterId == request.auth.uid
        && (
          isActiveStudent()
          || isActiveTeacher()
          || isActiveSuperAdmin()
        )
        && (
          !('classroomId' in request.resource.data)
          || request.resource.data.classroomId == null
          || (
            request.resource.data.classroomId is string
            && ownsClassroom(request.resource.data.classroomId)
          )
        );
      allow read: if signedIn() && (
        resource.data.submitterId == request.auth.uid
        || resource.data.studentId == request.auth.uid
        || isActiveSuperAdmin()
        || (
          'classroomId' in resource.data
          && resource.data.classroomId is string
          && ownsClassroom(resource.data.classroomId)
        )
      );

      /** 마스터 검수: 승인·반려·연결 콘텐츠 ID 기록 */
      allow update: if isActiveSuperAdmin();
    }

    // ——— video_material_requests ———
    match /video_material_requests/{reqId} {
      allow create: if signedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.submitterId == request.auth.uid
        && request.resource.data.materialType in ['share', 'paid', 'homework']
        && request.resource.data.videoUrl is string
        && request.resource.data.title is string
        && request.resource.data.subject is string
        && request.resource.data.audienceGrade is string
        && request.resource.data.description is string
        && (
          isActiveStudent()
          || isActiveTeacher()
          || isActiveSuperAdmin()
        )
        && (
          !('classroomId' in request.resource.data)
          || request.resource.data.classroomId == null
          || (
            request.resource.data.classroomId is string
            && ownsClassroom(request.resource.data.classroomId)
          )
        );
      allow read: if signedIn() && (
        resource.data.submitterId == request.auth.uid
        || isActiveSuperAdmin()
        || (
          'classroomId' in resource.data
          && resource.data.classroomId is string
          && ownsClassroom(resource.data.classroomId)
        )
      );

      allow update: if isActiveSuperAdmin();
    }

    // ——— sales_records ———
    match /sales_records/{saleId} {
      allow read: if signedIn() && (
        isActiveSuperAdmin()
        || resource.data.teacherId == request.auth.uid
        || resource.data.sellerId == request.auth.uid
      );
      allow create, update, delete: if isActiveSuperAdmin();
    }

    // ——— students (CRM) ———
    match /students/{studentId} {
      allow read: if isActiveSuperAdmin()
        || (isActiveTeacher() && resource.data.teacherId == request.auth.uid);

      allow create: if isActiveTeacher()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.email is string
        && request.resource.data.keys().hasAll(['teacherId', 'name', 'phone', 'email', 'createdAt']);

      allow update: if isActiveSuperAdmin()
        || (
          isActiveTeacher()
          && resource.data.teacherId == request.auth.uid
          && request.resource.data.teacherId == resource.data.teacherId
        );

      allow delete: if isActiveSuperAdmin()
        || (isActiveTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // ——— 지식 큐레이션 (마스터 전용) ———
    match /knowledge_curations/{curationId} {
      allow read: if isActiveSuperAdmin();

      allow create: if isActiveSuperAdmin()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerId', 'title', 'topicDomain', 'createdAt', 'updatedAt'])
        && request.resource.data.ownerId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.topicDomain is string
        && request.resource.data.topicDomain.size() <= 400
        && request.resource.data.createdAt != null
        && request.resource.data.updatedAt != null;

      allow update: if isActiveSuperAdmin()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isActiveSuperAdmin() && resource.data.ownerId == request.auth.uid;

      match /items/{itemId} {
        allow read: if isActiveSuperAdmin();

        allow create: if isActiveSuperAdmin()
          && get(/databases/$(database)/documents/knowledge_curations/$(curationId)).data.ownerId == request.auth.uid
          && request.resource.data.keys().hasAll(['type', 'title', 'url', 'savedAt'])
          && request.resource.data.type is string
          && request.resource.data.type in ['youtube', 'paper', 'news', 'file']
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 500
          && request.resource.data.url is string
          && request.resource.data.url.size() > 0
          && request.resource.data.url.size() <= 2000
          && request.resource.data.savedAt != null
          && (!('snippet' in request.resource.data) || (request.resource.data.snippet is string && request.resource.data.snippet.size() <= 2000))
          && (!('sourceLabel' in request.resource.data) || (request.resource.data.sourceLabel is string && request.resource.data.sourceLabel.size() <= 200))
          && (!('storagePath' in request.resource.data) || (request.resource.data.storagePath is string && request.resource.data.storagePath.size() > 0 && request.resource.data.storagePath.size() <= 500));

        allow delete: if isActiveSuperAdmin()
          && get(/databases/$(database)/documents/knowledge_curations/$(curationId)).data.ownerId == request.auth.uid;

        allow update: if false;
      }
    }

    match /knowledge_materials/{materialId} {
      allow read: if isActiveSuperAdmin();

      allow create: if isActiveSuperAdmin()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'ownerId',
          'curationId',
          'title',
          'bodyMarkdown',
          'sourceItemIds',
          'createdAt'
        ])
        && request.resource.data.ownerId is string
        && request.resource.data.curationId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.bodyMarkdown is string
        && request.resource.data.bodyMarkdown.size() > 0
        && request.resource.data.bodyMarkdown.size() <= 900000
        && request.resource.data.sourceItemIds is list
        && request.resource.data.createdAt != null;

      allow update: if isActiveSuperAdmin()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isActiveSuperAdmin() && resource.data.ownerId == request.auth.uid;
    }

    // ——— classrooms (강의실 개설·입장) ———
    match /classrooms/{classroomId} {
      /**
       * 읽기: 로그인 활성 계정은 카탈로그(전체 강의실 목록)용으로 문서 조회 가능.
       * memberStudentIds 등이 노출되므로 필요 시 별도 공개 요약 컬렉션으로 분리 검토.
       */
      allow read: if isActiveSuperAdmin()
        || (isSignedInActiveAccount() && resource.data.teacherId == request.auth.uid)
        || (
          isSignedInActiveAccount()
          && 'memberStudentIds' in resource.data
          && request.auth.uid in resource.data.memberStudentIds
        )
        || isSignedInActiveAccount();

      /** 승인 선생님 또는 슈퍼관리자(앱의 TeacherRoute·자료 관리와 동일) */
      allow create: if (isActiveTeacher() || isActiveSuperAdmin())
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.keys().hasAll(['teacherId', 'title', 'description', 'createdAt'])
        && (!('introduction' in request.resource.data) || (request.resource.data.introduction is string && request.resource.data.introduction.size() <= 950000))
        && (!('knowledgeMaterialId' in request.resource.data) || (request.resource.data.knowledgeMaterialId is string && request.resource.data.knowledgeMaterialId.size() <= 200))
        && (
          !('pricingType' in request.resource.data)
          || (
            request.resource.data.pricingType is string
            && request.resource.data.pricingType in ['free', 'paid']
          )
        );

      allow update: if isActiveSuperAdmin()
        || (
          isActiveTeacher()
          && resource.data.teacherId == request.auth.uid
          && request.resource.data.teacherId == resource.data.teacherId
        )
        || studentSelfEnrollFreeClassroom()
        || studentSelfLeaveClassroomMembers();

      allow delete: if isActiveSuperAdmin()
        || (isActiveTeacher() && resource.data.teacherId == request.auth.uid);

      /** 유료 수강 신청 (강사가 멤버 승인 전 연락처 수집) */
      match /enrollment_requests/{requestId} {
        function enrollmentClassroomData() {
          return get(/databases/$(database)/documents/classrooms/$(classroomId)).data;
        }
        function enrollmentClassroomMemberIds() {
          return (
            'memberStudentIds' in enrollmentClassroomData()
            && enrollmentClassroomData().memberStudentIds is list
          )
            ? enrollmentClassroomData().memberStudentIds
            : [];
        }
        allow read: if isActiveSuperAdmin()
          || (isSignedInActiveAccount() && resource.data.studentId == request.auth.uid)
          || (isActiveTeacher() && ownsClassroom(classroomId));

        allow create: if isActiveStudent()
          && exists(/databases/$(database)/documents/classrooms/$(classroomId))
          && requestId == request.auth.uid
          && enrollmentClassroomData().pricingType == 'paid'
          && !(request.auth.uid in enrollmentClassroomMemberIds())
          && request.resource.data.studentId == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.phone is string
          && request.resource.data.phone.size() >= 5
          && request.resource.data.phone.size() <= 40
          && request.resource.data.email is string
          && request.resource.data.email.size() >= 3
          && request.resource.data.email.size() <= 200
          && request.resource.data.createdAt != null
          && request.resource.data.keys().hasAll(['studentId', 'phone', 'email', 'status', 'createdAt'])
          && request.resource.data.keys().hasOnly(['studentId', 'phone', 'email', 'status', 'createdAt']);

        allow update: if isActiveSuperAdmin()
          || (
            isActiveTeacher()
            && ownsClassroom(classroomId)
            && resource.data.status == 'pending'
            && request.resource.data.studentId == resource.data.studentId
            && request.resource.data.phone == resource.data.phone
            && request.resource.data.email == resource.data.email
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedAt'])
            && request.resource.data.status in ['approved', 'rejected']
            && (
              !('reviewedAt' in request.resource.data)
              || request.resource.data.reviewedAt != null
            )
          );

        allow delete: if isActiveSuperAdmin()
          || (isActiveTeacher() && ownsClassroom(classroomId))
          || (
            isActiveStudent()
            && resource.data.studentId == request.auth.uid
            && resource.data.status in ['pending', 'rejected']
          );
      }

      /** 질의응답 (강의실 단위 스레드) */
      match /qa_posts/{postId} {
        allow read: if isSignedInActiveAccount();

        allow create: if isSignedInActiveAccount()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 8000
          && request.resource.data.createdAt != null
          && request.resource.data.keys().hasAll(['authorId', 'authorName', 'body', 'createdAt'])
          && (
            !('parentPostId' in request.resource.data)
            || request.resource.data.parentPostId == null
            || request.resource.data.parentPostId is string
          );

        allow update: if isSignedInActiveAccount()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.parentPostId == resource.data.parentPostId
          && request.resource.data.authorName == resource.data.authorName
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body']);

        allow delete: if isSignedInActiveAccount()
          && (
            resource.data.authorId == request.auth.uid
            || isActiveSuperAdmin()
            || (isActiveTeacher() && ownsClassroom(classroomId))
          );
      }
    }

    // ——— assignments (Signal Logic 학습지 배포) ———
    match /assignments/{aid} {
      function assignData() {
        return get(/databases/$(database)/documents/assignments/$(aid)).data;
      }

      allow read: if isActiveSuperAdmin()
        || (isActiveTeacher() && resource.data.teacherId == request.auth.uid)
        || (
          isActiveStudent()
          && resource.data.targetStudentIds.hasAny([request.auth.uid])
        );

      allow create: if (isActiveTeacher() || isActiveSuperAdmin())
        && request.auth.uid == request.resource.data.teacherId
        && request.resource.data.schemaVersion == 1
        && request.resource.data.keys().hasAll([
          'schemaVersion',
          'teacherId',
          'title',
          'passage',
          'analysis',
          'distributedAt',
          'targetStudentIds',
          'worksheetItems',
          'createdAt'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.passage is string
        && request.resource.data.passage.size() > 0
        && request.resource.data.passage.size() <= 120000
        && request.resource.data.analysis is map
        && request.resource.data.distributedAt != null
        && request.resource.data.targetStudentIds is list
        && request.resource.data.targetStudentIds.size() > 0
        && request.resource.data.targetStudentIds.size() <= 120
        && request.resource.data.worksheetItems is list
        && request.resource.data.worksheetItems.size() > 0
        && request.resource.data.worksheetItems.size() <= 60
        && (!('contentSource' in request.resource.data)
          || (
            request.resource.data.contentSource is string
            && request.resource.data.contentSource in ['ai', 'local']
          ))
        && (!('localAttachment' in request.resource.data)
          || (
            request.resource.data.localAttachment is map
            && request.resource.data.localAttachment.keys().hasAll(['storagePath', 'originalName'])
            && request.resource.data.localAttachment.storagePath is string
            && request.resource.data.localAttachment.storagePath.size() > 0
            && request.resource.data.localAttachment.storagePath.size() <= 500
            && request.resource.data.localAttachment.originalName is string
            && request.resource.data.localAttachment.originalName.size() > 0
            && request.resource.data.localAttachment.originalName.size() <= 240
          ));

      allow update: if (isActiveTeacher() || isActiveSuperAdmin())
        && resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.schemaVersion == resource.data.schemaVersion
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['title', 'distributedAt', 'targetStudentIds']);

      allow delete: if (isActiveTeacher() || isActiveSuperAdmin())
        && resource.data.teacherId == request.auth.uid;

      match /student_work/{sid} {
        allow read: if isActiveSuperAdmin()
          || (isActiveTeacher() && assignData().teacherId == request.auth.uid)
          || (
            isActiveStudent()
            && request.auth.uid == sid
            && assignData().targetStudentIds.hasAny([request.auth.uid])
          );

        allow create: if isActiveStudent()
          && request.auth.uid == sid
          && assignData().targetStudentIds.hasAny([request.auth.uid])
          && request.resource.data.studentId == request.auth.uid
          && request.resource.data.keys().hasAll(['studentId', 'answers', 'status', 'updatedAt'])
          && request.resource.data.answers is map
          && request.resource.data.status in ['draft', 'submitted']
          && (
            request.resource.data.status == 'draft'
            || request.resource.data.submittedAt is timestamp
          );

        allow update: if isActiveStudent()
          && request.auth.uid == sid
          && assignData().targetStudentIds.hasAny([request.auth.uid])
          && resource.data.studentId == request.auth.uid
          && request.resource.data.studentId == resource.data.studentId
          && !(resource.data.status == 'submitted')
          && request.resource.data.keys().hasAll(['studentId', 'answers', 'status', 'updatedAt'])
          && request.resource.data.answers is map
          && request.resource.data.status in ['draft', 'submitted']
          && (
            request.resource.data.status == 'draft'
            || request.resource.data.submittedAt is timestamp
          );
      }

      /** 학생 최종 제출 시 append-only 이벤트 (선생님 과제 상세에서 알림 목록) */
      match /submission_events/{eid} {
        allow read: if isActiveSuperAdmin()
          || (isActiveTeacher() && assignData().teacherId == request.auth.uid);

        allow create: if isActiveStudent()
          && assignData().targetStudentIds.hasAny([request.auth.uid])
          && request.auth.uid == request.resource.data.studentId
          && request.resource.data.kind == 'submitted'
          && request.resource.data.keys().hasAll(['studentId', 'kind', 'createdAt'])
          && request.resource.data.createdAt != null;

        allow update, delete: if false;
      }

      /** 과제 배포 수신자(이름·전화·이메일 등) — 담당 교사·슈퍼관리자만 읽기, 클라이언트 쓰기 불가 */
      match /distribution_recipients/{rid} {
        allow read: if isActiveSuperAdmin()
          || (
            isActiveTeacher()
            && assignData().teacherId == request.auth.uid
          );

        allow create, update, delete: if false;
      }
    }

    /** 이메일 링크용 일회성 토큰 — 서버(Admin SDK)만 읽기·쓰기 */
    match /external_worksheet_tokens/{tid} {
      allow read, write: if false;
    }

    // ——— homework_dispatches ———
    match /homework_dispatches/{dispatchId} {
      allow read: if isActiveSuperAdmin()
        || (isActiveTeacher() && resource.data.teacherId == request.auth.uid);

      allow create: if isActiveTeacher()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.homeworkCode is string
        && request.resource.data.message is string
        && request.resource.data.recipientStudentIds is list
        && request.resource.data.recipients is list
        && request.resource.data.keys().hasAll([
          'teacherId', 'homeworkCode', 'message', 'recipientStudentIds', 'recipients', 'createdAt'
        ]);

      allow update, delete: if false;
    }
  }
}
