{
  "functions": {
    "api/copy-storage-objects.mjs": {
      "maxDuration": 60
    },
    "api/woohyukmon-chat.mjs": {
      "maxDuration": 30
    },
    "api/generate-premium-textbook.mjs": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
