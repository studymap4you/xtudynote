# Copy to `.env.local` — values from Firebase Console → Project settings → Your apps (Web).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloud Functions (학습지 이메일 배포 등). Firebase 콘솔에 배포한 Functions 리전과 동일하게.
VITE_FIREBASE_FUNCTIONS_REGION=asia-northeast3
# 로컬 에뮬레이터: VITE_FIREBASE_FUNCTIONS_EMULATOR=true

# ——— 외부 이메일 배포 테스트용 (선생님 메일 SMTP) ———
# 실제 발송은 Cloud Functions 파라미터(콘솔)에도 동일 값을 넣어야 합니다. 로컬에서만 복사해 쓰려면 .env.local에 넣으세요.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=앱비밀번호
# MAIL_FROM=your.email@gmail.com
# APP_PUBLIC_ORIGIN=http://localhost:3000

# EmailJS — 템플릿 수신(To): {{email}}, 본문: homework_code, message, to_name
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# Google Drive Picker — OAuth Web client + Browser API key (HTTP referrer: http://localhost:3000/*)
# `npm run dev`는 vite.config 기준 포트 3000 (OAuth 승인된 원본과 동일하게 맞춤)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# OpenAI — Signal Logic 분석 (JSON 모드). 공개 배포 시에는 반드시 서버 경유로 전환하세요.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
