# Firebase Functions 파라미터(콘솔에서 설정하거나 deploy 시 주입)
# APP_PUBLIC_ORIGIN=https://your-domain.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@example.com
#
# Gmail 전용(위 SMTP 대신 사용 가능 — Firebase 콘솔 파라미터 이름은 GMAIL_USER / GMAIL_PASS)
# GMAIL_USER=you@gmail.com
# GMAIL_PASS=앱_비밀번호
# 로컬 에뮬레이터에서 dot 키도 지원: gmail.user / gmail.pass
